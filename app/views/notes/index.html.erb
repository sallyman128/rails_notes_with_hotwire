<div class="space-y-6">
  <div class="flex justify-between items-center">
    <h1 class="text-3xl font-bold text-gray-900">My Notes</h1>
    <%= link_to new_note_path, class: "bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700 transition-colors flex items-center gap-2" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
      </svg>
      New Note
    <% end %>
  </div>

  <% if @notes.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @notes.each do |note| %>
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 hover:shadow-md transition-shadow">
          <div class="p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-2 line-clamp-2">
              <%= link_to note.title, note_path(note), class: "hover:text-blue-600 transition-colors" %>
            </h3>
            <p class="text-gray-600 text-sm mb-4 line-clamp-3">
              <%= note.content %>
            </p>
            <div class="flex justify-between items-center text-xs text-gray-500">
              <span><%= note.created_at.strftime("%B %d, %Y") %></span>
              <div class="flex gap-2">
                <%= link_to "Edit", edit_note_path(note), class: "text-blue-600 hover:text-blue-800 transition-colors" %>
                <%= link_to "Delete", note_path(note), 
                    method: :delete, 
                    data: { turbo_method: :delete, turbo_confirm: "Are you sure?" },
                    class: "text-red-600 hover:text-red-800 transition-colors" %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-12">
      <div class="bg-gray-100 w-24 h-24 rounded-full flex items-center justify-center mx-auto mb-4">
        <svg class="w-12 h-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
        </svg>
      </div>
      <h3 class="text-lg font-medium text-gray-900 mb-2">No notes yet</h3>
      <p class="text-gray-600 mb-6">Create your first note to get started!</p>
      <%= link_to "Create Note", new_note_path, class: "bg-blue-600 text-white px-6 py-3 rounded-md hover:bg-blue-700 transition-colors" %>
    </div>
  <% end %>
</div>
