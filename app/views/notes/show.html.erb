<div class="max-w-4xl mx-auto">
  <div class="mb-6 flex justify-between items-start">
    <div>
      <h1 class="text-3xl font-bold text-gray-900 mb-2"><%= @note.title %></h1>
      <p class="text-gray-500 text-sm">
        Created on <%= @note.created_at.strftime("%B %d, %Y at %I:%M %p") %>
        <% if @note.updated_at != @note.created_at %>
          • Updated on <%= @note.updated_at.strftime("%B %d, %Y at %I:%M %p") %>
        <% end %>
      </p>
    </div>
    <div class="flex gap-3">
      <%= link_to edit_note_path(@note), class: "bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700 transition-colors flex items-center gap-2" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
        </svg>
        Edit
      <% end %>
      <%= link_to notes_path, class: "bg-gray-100 text-gray-700 px-4 py-2 rounded-md hover:bg-gray-200 transition-colors" do %>
        Back to Notes
      <% end %>
    </div>
  </div>

  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-8">
    <div class="prose max-w-none">
      <div class="whitespace-pre-wrap text-gray-700 leading-relaxed">
        <%= @note.content %>
      </div>
    </div>
  </div>

  <div class="mt-6 flex justify-between items-center">
    <%= link_to "← Back to Notes", notes_path, class: "text-blue-600 hover:text-blue-800 transition-colors" %>
    <%= link_to note_path(@note), 
        method: :delete, 
        data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete this note?" },
        class: "text-red-600 hover:text-red-800 transition-colors" do %>
      Delete Note
    <% end %>
  </div>
</div>
